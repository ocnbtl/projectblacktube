{
  "manifest_version": 3,
  "name": "Purrify Music",
  "description": "Create artist and song blocklists for YouTube Music and autoskip blocked matches.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://music.youtube.com/*"],
  "background": {
    "service_worker": "src/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Purrify Music",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ]
}

